        { "id": "osv-scanner", "requirement": "required" },
        { "id": "gitleaks", "requirement": "required" },
        { "id": "license-inventory", "requirement": "required" },
        { "id": "ast-grep", "requirement": "required" },
        { "id": "knip", "requirement": "required" },
        { "id": "jscpd", "requirement": "required" },
        { "id": "semgrep", "requirement": "optional" },
        { "id": "codeql", "requirement": "optional" }
      ]
    },
    {
      "id": "security",
      "description": "Security and supply-chain controls with all security engines and Git history scanning required.",
