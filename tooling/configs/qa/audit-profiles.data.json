        { "id": "npm-audit-signatures", "requirement": "required" },
        { "id": "osv-scanner", "requirement": "required" },
        { "id": "gitleaks", "requirement": "required" },
        { "id": "license-inventory", "requirement": "excluded" },
        { "id": "ast-grep", "requirement": "required" },
        { "id": "knip", "requirement": "excluded" },
        { "id": "jscpd", "requirement": "excluded" },
        { "id": "semgrep", "requirement": "required" },
        { "id": "codeql", "requirement": "required" }
      ]
    },
    {
      "id": "release",
      "description": "Complete release audit with every registered control and Git history scanning required.",
      "gitleaksScopes": ["worktree", "history"],
      "controls": [
        { "id": "full-product-coverage", "requirement": "required" },
        { "id": "audit-evidence", "requirement": "required" },
